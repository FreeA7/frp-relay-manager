bindAddr = "0.0.0.0"
bindPort = 7000

auth.token = "{{ .Envs.FRP_RELAY_FRPS_TOKEN }}"

webServer.addr = "127.0.0.1"
webServer.port = 7500
webServer.user = "admin"
webServer.password = "{{ .Envs.FRP_RELAY_FRPS_DASHBOARD_PASSWORD }}"

vhostHTTPPort = 8080
subDomainHost = "tunnel.freea7.fun"

allowPorts = [
  { start = 20000, end = 49999 }
]

log.to = "/var/log/frps.log"
log.level = "info"
log.maxDays = 7
